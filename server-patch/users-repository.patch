+  /**
+   * Returns the full row (incl. password hash) by ID.
+   * Used only when verifying the current password before a sensitive change.
+   */
+  getUserWithPasswordById(userId: number): UserRow | undefined {
+    const db = getConnection();
+    return db
+      .prepare('SELECT * FROM users WHERE id = ? AND is_active = 1')
+      .get(userId) as UserRow | undefined;
+  },
+
+  /** Updates the password hash. Returns true if a row was affected. */
+  updatePassword(userId: number, newHash: string): boolean {
+    const db = getConnection();
+    const r = db
+      .prepare('UPDATE users SET password_hash = ? WHERE id = ? AND is_active = 1')
+      .run(newHash, userId);
+    return r.changes > 0;
+  },
+
+  /**
