-router.put('/account/password', authenticateToken, async (req, res) => {
+router.put('/account/password', authenticateToken, accountChangeLimiter, async (req, res) => {
   if (IS_PLATFORM) {
     return res.status(403).json({ error: 'Account management is disabled in platform mode' });
   }
