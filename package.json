{
  "name": "account",
  "version": "0.2.0-experimental.1",
  "private": true,
  "description": "Account management plug-in (change username/password) for Claude Code UI by siteboon. Independent project, not affiliated with Anthropic.",
  "author": "AlKindy (الكندي) — Nawras",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nawras-io/claudecodeui-plugin-account.git"
  },
  "homepage": "https://github.com/Nawras-io/claudecodeui-plugin-account#readme",
  "bugs": "https://github.com/Nawras-io/claudecodeui-plugin-account/issues",
  "type": "module",
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "esbuild src/index.ts --bundle --format=esm --target=es2020 --outfile=dist/index.js",
    "build:server": "esbuild src/server/server.ts --bundle --platform=node --format=esm --target=node18 --outfile=dist/server.js --external:better-sqlite3 --external:bcrypt",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
